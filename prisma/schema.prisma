generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Order {
  id            String   @id @default(cuid())
  userId        String
  totalAmount   Float
  items         String
  paymentMethod String   @default("paytm")
  transactionId String?
  status        String   @default("pending")
  customerName  String?
  phone         String?
  email         String?
  address       String?
  city          String?
  state         String?
  pincode       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  price       Float
  image       String
  category    String
  images      String
  bulkPricing String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Offer {
  id              String   @id @default(cuid())
  festival        String
  title           String
  subtitle        String
  code            String   @unique
  validTill       String
  emoji           String
  glow            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  darkBg          String
  darkTextAccent  String
  discountPercent Float
  isActive        Boolean  @default(true)
  lightBg         String
  lightTextAccent String
  minAmount       Float    @default(0)
  minQuantity     Int      @default(0)
}

model Service {
  id        String   @id @default(cuid())
  title     String
  desc      String
  longDesc  String
  image     String
  tag       String
  iconName  String   @default("Sparkles")
  features  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
